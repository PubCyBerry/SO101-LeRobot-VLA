# syntax=docker/dockerfile:1.7
# =============================================================================
# Dockerfile.lerobot — LeRobot SO-101 Teleoperation / Record / Replay / Train
# Base  : nvidia/cuda:12.8.0-runtime-ubuntu24.04
# Python: 3.11 (managed by uv)
# Deps  : pyproject.toml [dependency-groups.teleop] 만 설치
#
# ※ SmolVLA / GR00T 등 정책 서버용 의존성은 Dockerfile.smolvla 에서 별도 빌드.
#   teleop 이미지에는 추론 모델 의존성을 포함하지 않는다 (안정성 격리).
#
# ■ 레이어 캐시 설계 (변경 빈도 낮은 순)
# ─────────────────────────────────────────
#   Stage base      : apt 빌드 전용 도구             → 거의 변경 없음
#   Stage uv        : uv 바이너리                    → 거의 변경 없음
#   Stage python    : Python 3.11 + venv             → 거의 변경 없음
#   Stage torch     : torch / torchvision            → PyTorch 버전 변경 시만
#   Stage teleop    : lerobot[feetech] 등            → lerobot 버전 변경 시만
#   Stage app       : 클린 CUDA 베이스 + venv 복사  → 자주 변경
#
# ■ 핵심 전략
#   - torch 를 별도 스테이지로 분리 → lerobot 버전만 바뀌어도 torch 재다운로드 없음
#   - uv sync --group teleop --group async → grpcio 만 추가, 추론(smolvla) / isaac / dev 그룹 배제
#   - pyproject.toml constraints 기반 설치 (lock 없음 — 재현성 강화 시 --frozen + uv.lock 전환)
#   - Slim final stage: app 스테이지는 클린 베이스에서 시작 → build-essential(~300 MB) +
#     git + -dev 헤더 등 빌드 도구를 최종 이미지에서 완전 제거 (~400 MB 절감)
# =============================================================================

# ── Stage 1: System dependencies ─────────────────────────────────────────────
FROM nvidia/cuda:12.8.0-runtime-ubuntu24.04 AS base

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Asia/Seoul

# ── 빌드 전용 패키지만 설치 (런타임 패키지는 app 스테이지에서 별도 설치) ──────────
# app 스테이지는 이 base 를 상속하지 않으므로 여기서는 컴파일에 필요한 패키지만 설치.
# 런타임 전용(ffmpeg, libsm6, mesa-vulkan-drivers, udev 등)을 제외해 빌드 캐시를 경량화.
RUN apt-get update && apt-get install -y --no-install-recommends \
        # 빌드 핵심 도구 (curl 불필요 — uv 는 COPY --from 으로 설치)
        build-essential \
        git \
        ca-certificates \
        # Python 네이티브 확장 컴파일 의존
        python3-dev \
        libffi-dev \
        libssl-dev \
        # AV 코덱 헤더 (PyAV 등 sdist 빌드 대비)
        libavcodec-dev \
        libavformat-dev \
        libswscale-dev \
        # evdev Python 패키지 헤더 (C 확장 빌드 시 필요)
        libevdev-dev \
        # USB 라이브러리 (pyusb 등 C 확장 빌드 시 필요)
        libusb-1.0-0 \
        libusb-1.0-0-dev \
    # apt 캐시를 같은 레이어에서 삭제해 빌드 이미지 크기 최소화
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# ── Stage 2: uv package manager ──────────────────────────────────────────────
# BuildKit multi-stage COPY 패턴으로 uv 바이너리를 직접 복사:
#   - curl | sh 방식 대비 빠르고 (네트워크 요청 1회 → Docker 레이어 pull 활용)
#   - BuildKit 캐시로 재빌드 시 네트워크 없이 재사용
#   - curl 의존성 제거 → base 스테이지 경량화
# 버전 고정이 필요하면 태그를 ghcr.io/astral-sh/uv:0.x.y 형태로 변경.
FROM base AS uv-installer

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv
RUN uv --version

# ── Stage 3: Python 3.11 + virtual-env ───────────────────────────────────────
FROM uv-installer AS python-setup

ENV VIRTUAL_ENV=/opt/venv \
    # uv 는 managed CPython 만 사용 (시스템 Python 무시)
    UV_PYTHON_PREFERENCE=only-managed \
    UV_PYTHON=3.11 \
    # .pyc 파일을 빌드 시점에 미리 컴파일 → 컨테이너 기동 속도 향상
    UV_COMPILE_BYTECODE=1 \
    # copy 모드: hardlink 불가 환경(overlay fs) 대비
    UV_LINK_MODE=copy

# Pin Python 3.11 (uv downloads the managed CPython build).
# `ulimit -Sn 65536`: uv 가 stdlib pyc 컴파일 단계에서 호스트 CPU 수만큼 워커를
# 띄우고 각 워커가 자체 Tokio runtime 을 만들어 fd 를 빠르게 소모한다. Docker 의
# 기본 soft fd 한도(1024) 로는 다코어 호스트(예: 224 코어)에서 "Too many open files"
# panic 이 발생. hard 한도(1048576) 범위 안에서 soft 를 끌어올려 회피.
# 자세한 내용은 docs/TROUBLESHOOTING.md 의 "uv python install Too many open files"
# 항목 참고.
# ① 크리티컬 작업 — 실패 시 빌드가 실제로 중단되어야 함
RUN ulimit -Sn 65536 \
    && uv python install 3.11 \
    && uv venv --python 3.11 ${VIRTUAL_ENV}

# ② stdlib 불필요 모듈 제거 (클린업 — 실패해도 빌드 계속)
# 이전 RUN 과 분리함으로써 ①의 실패가 '; true' 에 의해 무시되는 버그를 방지.
#   test/      : CPython 테스트 스위트 (~30 MB)
#   idlelib/   : IDLE 에디터 (~3 MB)
#   tkinter/   : GUI 툴킷 (컨테이너에 Tcl/Tk 미설치) (~1 MB)
#   turtledemo/: Turtle 데모
#   lib2to3/   : Python 2→3 변환 도구 (3.11에서 deprecated) (~3 MB)
#   ensurepip/ : pip 번들러 (uv 사용으로 불필요) (~3 MB)
RUN find /root/.local/share/uv/python -type d \
        \( -name test -o -name idlelib -o -name tkinter \
           -o -name turtledemo -o -name lib2to3 -o -name ensurepip \) \
        -maxdepth 8 | xargs rm -rf 2>/dev/null; true

ENV PATH="${VIRTUAL_ENV}/bin:$PATH"

# ── Stage 4: torch / torchvision (별도 캐시 레이어) ─────────────────────────
# lerobot 버전이 바뀌어도 이 레이어는 재사용됨.
# pyproject.toml teleop 그룹의 torch==2.7.0 / cu128 index 를 직접 참조.
FROM python-setup AS torch-layer

WORKDIR /build

# pyproject.toml 만 먼저 복사 (index 정보 참조용)
COPY pyproject.toml ./

# torch / torchvision 을 teleop 그룹 버전과 동일하게 선행 설치.
#
# ■ 안정성 옵션 (--mount=cache + ENV 들):
#   torch + nvidia-cudnn/cublas/nccl/cusparse 등 CUDA 휠 합계 ~3GB 를 받는데
#   pypi.nvidia.com CDN 이 동일 IP 의 동시 large-file 다운로드를 throttle 한다.
#   uv 기본값 (동시 다운로드 ≥8, HTTP timeout 30s) 으로는 일부 connection 이
#   "operation timed out" 으로 끊겨 빌드가 통째로 실패한다. 자세한 내용은
#   docs/TROUBLESHOOTING.md "pypi.nvidia.com torch CUDA 휠 다운로드 timeout" 참고.
#
#   - --mount=type=cache : BuildKit 영구 캐시. 한 번 받은 휠은 이미지에는 들어가지
#                          않으면서 다음 빌드에서 재사용. `--no-cache` 플래그 제거.
#   - UV_HTTP_TIMEOUT=600 : 단일 요청 타임아웃 10분 (기본 30s → 큰 휠 안전)
#   - UV_CONCURRENT_DOWNLOADS=2 : 동시 다운로드 2개로 제한 → CDN throttling 회피
RUN --mount=type=cache,target=/root/.cache/uv,sharing=locked \
    ulimit -Sn 65536 \
    && UV_HTTP_TIMEOUT=600 \
       UV_CONCURRENT_DOWNLOADS=2 \
       uv pip install \
           "torch==2.7.0" \
           "torchvision==0.22.0" \
           --index-url "https://download.pytorch.org/whl/cu128"


# ── Stage 5: teleop + async 그룹 설치 ───────────────────────────────────────
# pyproject.toml [dependency-groups]:
#   teleop : lerobot[feetech] + evdev + ffmpeg (실물 Arm 의존성)
#   async  : grpcio + protobuf — lerobot.async_inference.robot_client 가 정책
#            서버에 gRPC 로 붙어 follower arm 을 구동하는 `policy-client` 모드에 필요.
#            패키지 크기 ~50 MB 로 가볍고 transformers 등 무거운 의존성을 끌어오지
#            않아 teleop 안정성에 영향이 없다 (smolvla / GR00T 본체 의존성은 여전히
#            Dockerfile.smolvla 에만 설치).
FROM torch-layer AS teleop-deps

# uv.lock 없이 pyproject.toml constraints 만으로 설치 (로컬 lock 환경에 종속되지 않음).
# 재현성이 필요하면 --frozen + COPY uv.lock 패턴으로 전환 가능.
# pyproject.toml 은 torch-layer 에서 상속되므로 재복사 불필요.

# Stage 4 와 동일한 안정성 옵션. BuildKit 캐시 마운트로 휠 재다운로드 회피.
# ulimit -Sn 65536: uv 가 설치 후 패키지의 .pyc 를 컴파일할 때 fd 폭주 회피
# (Stage 3 의 동일 RUN 주석 참고 — UV_COMPILE_BYTECODE=1 이 stage 간 ENV 로
# 상속되므로 모든 uv 호출 RUN 에 동일 ulimit 가 필요하다).
RUN --mount=type=cache,target=/root/.cache/uv,sharing=locked \
    ulimit -Sn 65536 \
    && UV_HTTP_TIMEOUT=600 \
       UV_CONCURRENT_DOWNLOADS=2 \
       uv sync \
           --active \
           --group teleop \
           --group async \
           --no-install-project

# venv 내 런타임 불필요 파일 제거 → COPY --from 전송량 감소:
#   tests/ / test/ / benchmarks/ : 패키지 테스트 디렉터리
#   *.pyi                         : 타입 스텁 (mypy/pyright 전용, Python 런타임 미사용)
#   dist-info/RECORD              : pip 설치 매니페스트 (런타임 불필요, 패키지당 수십 KB)
RUN sp=/opt/venv/lib/python3.11/site-packages; \
    find "$sp" -maxdepth 2 -type d \( -name tests -o -name test -o -name benchmarks \) \
        | xargs rm -rf 2>/dev/null; \
    find "$sp" -name "*.pyi" -delete 2>/dev/null; \
    find "$sp" -path "*/dist-info/RECORD" -delete 2>/dev/null; \
    true


# ── Stage 6: Slim runtime (이미지 크기 최적화) ──────────────────────────────
# build-essential / git / -dev 헤더 등 빌드 전용 패키지를 최종 이미지에서 완전 제거.
# 클린 CUDA 베이스에서 시작해 런타임 라이브러리만 설치하고, venv + managed Python
# 은 COPY --from 으로 빌드 스테이지에서 가져온다.
# 절감 효과: build-essential(~300 MB) + git(~30 MB) + -dev 헤더(~70 MB) ≈ 400 MB
FROM nvidia/cuda:12.8.0-runtime-ubuntu24.04 AS app

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Asia/Seoul

# 런타임 전용 패키지 (빌드 도구 없음):
#   libssl3 / libffi8          : uv managed CPython 동적 링크 (ssl / ctypes 모듈)
#   libncurses6 / libbz2-1.0 / liblzma5 / zlib1g : CPython 표준 라이브러리 의존
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        # OpenCV / video runtime
        ffmpeg \
        libsm6 \
        libxext6 \
        libgl1 \
        libglib2.0-0 \
        # Vulkan runtime (디버그 바이너리 제외)
        mesa-vulkan-drivers \
        libxkbcommon-x11-0 \
        # USB / serial runtime (Feetech & Dynamixel)
        libevdev2 \
        libusb-1.0-0 \
        udev \
        # LeRobot 음성 알림
        speech-dispatcher \
        espeak-ng \
        # uv managed CPython 동적 링크 의존
        libssl3 \
        libffi8 \
        libncurses6 \
        libbz2-1.0 \
        liblzma5 \
        zlib1g \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# venv (Python 3.11 + 전체 패키지) 및 uv managed CPython 을 빌드 스테이지에서 복사.
# venv 내 python3 심볼릭 링크가 /root/.local/share/uv/python/... 를 가리키므로 둘 다 필요.
COPY --from=teleop-deps /opt/venv /opt/venv
COPY --from=teleop-deps /root/.local/share/uv/python /root/.local/share/uv/python

# udev 규칙: ttyUSB / ttyACM 에 dialout 그룹 접근 권한 부여
COPY docker/99-feetech.rules /etc/udev/rules.d/99-feetech.rules

# 실행 진입점 (teleop / record / replay / bash 모드 지원)
COPY docker/lerobot-entrypoint.sh /usr/local/bin/entrypoint.sh
# policy-client shim — lerobot#3078 워크어라운드 (robot config 사전 import 후 robot_client 실행)
COPY docker/policy-client-shim.py /usr/local/bin/policy-client-shim.py

# Stdin 기반 키보드 리스너 패치 — WSLg + Windows Terminal 에서 pynput 의 X11
# RECORD 백엔드가 키 이벤트를 받지 못하는 문제를 우회한다 (자세한 내용은
# docs/TROUBLESHOOTING.md 의 "pynput X 서버 미연결" 항목 참고).
COPY docker/lerobot_keyboard_stdin.py /opt/venv/lib/python3.11/site-packages/lerobot_keyboard_stdin.py
COPY docker/lerobot_keyboard_stdin.pth /opt/venv/lib/python3.11/site-packages/lerobot_keyboard_stdin.pth

# 런타임 환경 변수 고정
# HF_HOME 을 /workspace/.cache/huggingface 로 옮긴 이유: 컨테이너를 호스트 UID
# (non-root) 로 실행하면 /root 안을 traverse 할 수 없기 때문.
# PYTHONNOUSERSITE=1 : user site-packages 경로 스캔 생략 → Python 시작 속도 향상
# PYTHONUTF8=1       : locale 감지 없이 UTF-8 강제 → Python 시작 시 locale 서브프로세스 생략
ENV VIRTUAL_ENV=/opt/venv \
    PATH="/opt/venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=0 \
    PYTHONNOUSERSITE=1 \
    PYTHONUTF8=1 \
    HF_HOME=/workspace/.cache/huggingface

# 모든 설정을 하나의 RUN 으로 통합 → 이미지 레이어 수 감소:
#   1) 실행 권한 부여
#   2) workspace 디렉터리 생성 + 권한 개방
#   3) lerobot 버전 파일 생성 (cold start 최적화)
#   4) /root traverse 허용 (non-root 컨테이너용)
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/policy-client-shim.py \
    && mkdir -p /workspace/.cache/huggingface /workspace/datasets /workspace/logs /workspace/outputs \
    && chmod -R 0777 /workspace \
    && python -c "import importlib.metadata; open('/opt/lerobot_version.txt','w').write(importlib.metadata.version('lerobot'))" \
    && chmod 0755 /root

# 기본 실행: teleop 모드 (docker-compose CMD 또는 직접 override 가능)
ENTRYPOINT ["entrypoint.sh"]
CMD ["bash"]