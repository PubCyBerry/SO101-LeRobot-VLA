# syntax=docker/dockerfile:1.7
# =============================================================================
# Dockerfile.smolvla — LeRobot Async Inference Policy Server (SmolVLA)
# Base  : nvidia/cuda:12.8.0-runtime-ubuntu24.04
# Python: 3.11 (managed by uv)
# Deps  : pyproject.toml [dependency-groups.smolvla] + [dependency-groups.async]
#
# ■ 이 이미지의 책임
#   ┌────────────────────────────────────────────────────────────────────────┐
#   │ docker compose 의 `lerobot-policy-server` 서비스가 이 이미지를 사용한다.│
#   │ entrypoint.sh 의 `policy-server` 모드만 실제로 호출되지만, train / eval│
#   │ / bash 모드도 동일 이미지로 SmolVLA 정책을 다룰 때 재사용 가능.       │
#   └────────────────────────────────────────────────────────────────────────┘
#
# ■ teleop 이미지와의 차이
#   - 직렬/USB 툴체인(libevdev, libusb, udev, speech-dispatcher) 제거
#     → 로봇 직결이 없는 순수 추론 서버, 공격면 축소
#   - lerobot[feetech] → lerobot[smolvla]
#     → Feetech 서보 SDK 제거, transformers / num2words / accelerate 추가
#   - grpcio / protobuf 추가 → async_inference.policy_server / robot_client
#
# ■ 향후 확장 지점
#   - GR00T N1.5: flash-attn 휠 필요 — devel 베이스 + build-essential 로 전환,
#                  ARG TARGET_GPU=(ampere|hopper) 로 휠 분기 예정
#   - 원격 inference: Linux H100 서버에서 빌드해 도커 레지스트리 push,
#                      Windows 클라이언트는 record / robot_client 만 실행
#
# ■ 레이어 캐시 설계 (Dockerfile.lerobot 과 Stage 1-4 공유)
# ─────────────────────────────────────────
#   Stage base      : apt 빌드 전용 도구             → 거의 변경 없음
#   Stage uv        : uv 바이너리                    → 거의 변경 없음
#   Stage python    : Python 3.11 + venv             → 거의 변경 없음
#   Stage torch     : torch / torchvision            → PyTorch 버전 변경 시만
#   Stage policy    : lerobot[smolvla] + grpcio      → lerobot/transformers 변경 시만
#   Stage app       : 클린 CUDA 베이스 + venv 복사  → 자주 변경 (~400 MB 절감)
# =============================================================================

# ── Stage 1: System dependencies ─────────────────────────────────────────────
# teleop 이미지의 apt 목록에서 USB / serial / speech 패키지를 제외한 minimal 셋.
# OpenCV / ffmpeg 는 lerobot 패키지가 import 단계에서 의존하므로 유지.
FROM nvidia/cuda:12.8.0-runtime-ubuntu24.04 AS base

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Asia/Seoul

# ── 빌드 전용 패키지만 설치 (런타임 패키지는 app 스테이지에서 별도 설치) ──────────
# app 스테이지는 이 base 를 상속하지 않으므로 컴파일에 필요한 패키지만 설치.
# 런타임 전용(ffmpeg, libsm6, libgl1 등)을 제외해 빌드 캐시를 경량화.
# flash-attn 빌드가 필요할 때는 build-essential + python3-dev 가 여기 있으면 된다.
RUN apt-get update && apt-get install -y --no-install-recommends \
        # 빌드 핵심 도구 (sdist fallback 및 향후 flash-attn 대비; curl 불필요)
        build-essential \
        git \
        ca-certificates \
        # Python 네이티브 확장 컴파일 의존
        python3-dev \
        libffi-dev \
        libssl-dev \
        # AV 코덱 헤더 (PyAV 등 sdist 빌드 대비)
        libavcodec-dev \
        libavformat-dev \
        libswscale-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# ── Stage 2: uv package manager ──────────────────────────────────────────────
# curl | sh 대신 BuildKit COPY --from 으로 uv 바이너리를 직접 복사.
# Dockerfile.lerobot 과 동일 패턴 — 캐시 공유 및 curl 의존성 제거.
FROM base AS uv-installer

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv
RUN uv --version

# ── Stage 3: Python 3.11 + virtual-env ───────────────────────────────────────
FROM uv-installer AS python-setup

ENV VIRTUAL_ENV=/opt/venv \
    UV_PYTHON_PREFERENCE=only-managed \
    UV_PYTHON=3.11 \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

# `ulimit -Sn 65536`: 다코어 호스트에서 uv 의 stdlib pyc 컴파일이 fd 를 폭주시켜
# "Too many open files" 로 panic 하는 문제 회피. Dockerfile.lerobot 의 동일 RUN
# 주석 참고.
# ① 크리티컬 작업 — 실패 시 빌드가 실제로 중단되어야 함
RUN ulimit -Sn 65536 \
    && uv python install 3.11 \
    && uv venv --python 3.11 ${VIRTUAL_ENV}

# ② stdlib 불필요 모듈 제거 (클린업 — 실패해도 빌드 계속)
# Dockerfile.lerobot 과 동일 분리 패턴 — 상세 내용은 해당 파일 참고.
RUN find /root/.local/share/uv/python -type d \
        \( -name test -o -name idlelib -o -name tkinter \
           -o -name turtledemo -o -name lib2to3 -o -name ensurepip \) \
        -maxdepth 8 | xargs rm -rf 2>/dev/null; true

ENV PATH="${VIRTUAL_ENV}/bin:$PATH"

# ── Stage 4: torch / torchvision (Dockerfile.lerobot 과 동일 핀) ────────────
# 두 이미지가 동일 RUN 명령을 사용하므로 BuildKit 이 자동으로 캐시 공유.
FROM python-setup AS torch-layer

WORKDIR /build

COPY pyproject.toml ./

# BuildKit 캐시 마운트 + 동시 다운로드 제한 + 긴 timeout + ulimit raise —
# Dockerfile.lerobot 의 동일 RUN 주석 참고 (pypi.nvidia.com CDN throttling +
# uv-compile 의 fd 폭주 둘 다 회피).
RUN --mount=type=cache,target=/root/.cache/uv,sharing=locked \
    ulimit -Sn 65536 \
    && UV_HTTP_TIMEOUT=600 \
       UV_CONCURRENT_DOWNLOADS=2 \
       uv pip install \
           "torch==2.7.0" \
           "torchvision==0.22.0" \
           --index-url "https://download.pytorch.org/whl/cu128"


# ── Stage 5: SmolVLA + async 그룹 설치 ──────────────────────────────────────
# pyproject.toml [dependency-groups]:
#   smolvla : lerobot[smolvla] + num2words + accelerate + safetensors
#   async   : grpcio + protobuf
# teleop / isaac / dev 그룹은 배제.
FROM torch-layer AS policy-deps

# pyproject.toml 은 torch-layer 에서 상속되므로 재복사 불필요.
RUN --mount=type=cache,target=/root/.cache/uv,sharing=locked \
    ulimit -Sn 65536 \
    && UV_HTTP_TIMEOUT=600 \
       UV_CONCURRENT_DOWNLOADS=2 \
       uv sync \
           --active \
           --group smolvla \
           --group async \
           --no-install-project

# venv 내 런타임 불필요 파일 제거 → COPY --from 전송량 감소:
#   tests/ / test/ / benchmarks/ : transformers 등 대형 패키지 포함 테스트 디렉터리
#   *.pyi                         : 타입 스텁 (런타임 미사용)
#   dist-info/RECORD              : pip 매니페스트 (패키지당 수십 KB, 런타임 불필요)
RUN sp=/opt/venv/lib/python3.11/site-packages; \
    find "$sp" -maxdepth 2 -type d \( -name tests -o -name test -o -name benchmarks \) \
        | xargs rm -rf 2>/dev/null; \
    find "$sp" -name "*.pyi" -delete 2>/dev/null; \
    find "$sp" -path "*/dist-info/RECORD" -delete 2>/dev/null; \
    true


# ── Stage 6: Slim runtime (이미지 크기 최적화) ──────────────────────────────
# build-essential / git / -dev 헤더 등 빌드 전용 패키지를 최종 이미지에서 제거.
# Dockerfile.lerobot 과 동일한 slim 전략 — USB/serial/speech 패키지는 정책 서버에 불필요.
FROM nvidia/cuda:12.8.0-runtime-ubuntu24.04 AS app

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Asia/Seoul

# 런타임 전용 패키지 (빌드 도구 없음):
#   libssl3 / libffi8          : uv managed CPython 동적 링크 (ssl / ctypes 모듈)
#   libncurses6 / libbz2-1.0 / liblzma5 / zlib1g : CPython 표준 라이브러리 의존
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        # OpenCV / video runtime (lerobot import 단계의 cv2 / ffmpeg 의존)
        ffmpeg \
        libsm6 \
        libxext6 \
        libgl1 \
        libglib2.0-0 \
        # uv managed CPython 동적 링크 의존
        libssl3 \
        libffi8 \
        libncurses6 \
        libbz2-1.0 \
        liblzma5 \
        zlib1g \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# venv (Python 3.11 + 전체 패키지) 및 uv managed CPython 을 빌드 스테이지에서 복사.
COPY --from=policy-deps /opt/venv /opt/venv
COPY --from=policy-deps /root/.local/share/uv/python /root/.local/share/uv/python

# 정책 서버 전용 진입점 (prepare-model / policy-server / info / bash / python).
COPY docker/server-entrypoint.sh /usr/local/bin/entrypoint.sh

# HF_HOME 을 /workspace/.cache/huggingface 로 옮긴 이유: lerobot 서비스와 동일.
# 컨테이너를 호스트 UID (non-root) 로 실행하면 /root 를 traverse 못하기 때문.
# PYTHONNOUSERSITE=1 : user site-packages 경로 스캔 생략 → Python 시작 속도 향상
# PYTHONUTF8=1       : locale 감지 없이 UTF-8 강제 → Python 시작 시 locale 서브프로세스 생략
ENV VIRTUAL_ENV=/opt/venv \
    PATH="/opt/venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=0 \
    PYTHONNOUSERSITE=1 \
    PYTHONUTF8=1 \
    HF_HOME=/workspace/.cache/huggingface

# 모든 설정을 하나의 RUN 으로 통합 → 이미지 레이어 수 감소:
#   1) 실행 권한 부여
#   2) workspace 디렉터리 생성 + 권한 개방
#   3) lerobot 버전 파일 생성 (cold start 최적화)
#   4) /root traverse 허용 (non-root 컨테이너용)
RUN chmod +x /usr/local/bin/entrypoint.sh \
    && mkdir -p /workspace/.cache/huggingface /workspace/datasets /workspace/logs /workspace/outputs \
    && chmod -R 0777 /workspace \
    && python -c "import importlib.metadata; open('/opt/lerobot_version.txt','w').write(importlib.metadata.version('lerobot'))" \
    && chmod 0755 /root

ENTRYPOINT ["entrypoint.sh"]
CMD ["policy-server"]
