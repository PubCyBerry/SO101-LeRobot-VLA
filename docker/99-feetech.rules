# /etc/udev/rules.d/99-feetech.rules
# Feetech STS3215 / USB-Serial 어댑터에 dialout 그룹 접근 권한 부여
# (컨테이너 내부용; 호스트 Windows/WSL 에서는 별도 설정 불필요)

# CH340 (가장 일반적인 USB-Serial 칩)
SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="7523", \
    MODE="0666", GROUP="dialout", SYMLINK+="feetech%n"

# CP210x (Silicon Labs)
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", \
    MODE="0666", GROUP="dialout", SYMLINK+="feetech%n"

# FTDI FT232 계열
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", \
    MODE="0666", GROUP="dialout", SYMLINK+="feetech%n"

SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6014", \
    MODE="0666", GROUP="dialout", SYMLINK+="feetech%n"

# UVC 카메라 (캡처·메타데이터 노드)
SUBSYSTEM=="video4linux", KERNEL=="video[0-9]*", MODE="0666", GROUP="video"

# 범용 USB-Serial fallback (모든 ttyUSB/ttyACM)
KERNEL=="ttyUSB[0-9]*", MODE="0666", GROUP="dialout"
KERNEL=="ttyACM[0-9]*", MODE="0666", GROUP="dialout"
