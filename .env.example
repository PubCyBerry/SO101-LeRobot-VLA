# docker-compose 가 참조하는 환경 변수.
# =============================================================================
#
# 사용법:
#   cp .env.example .env
#   # 아래 값들을 실제 환경에 맞게 수정하세요
#   docker compose --env-file .env -f docker/docker-compose.yaml up teleop
#
# ■ Windows 11 USB 포트 확인 방법
#   PowerShell (관리자):
#     usbipd list
#     usbipd attach --wsl --busid <BUS_ID>
#   WSL2 터미널:
#     ls /dev/ttyUSB*     # → 예: /dev/ttyUSB0, /dev/ttyUSB1
#     ls /dev/ttyACM*     # Feetech이 ACM으로 잡히는 경우
#
# ■ 모드별 필수 변수 요약
#   teleop            : LEADER_PORT FOLLOWER_PORT 카메라 변수 일체
#   record            : teleop 변수 전체 + HF_DATASET_REPO_ID SINGLE_TASK ...
#   replay            : FOLLOWER_PORT + HF_DATASET_REPO_ID EPISODE_INDEX
#   calibrate         : CALIBRATE_TARGET + (LEADER or FOLLOWER) PORT
#   setup-motors      : CALIBRATE_TARGET + (LEADER or FOLLOWER) PORT
#   find-joint-limits : LEADER_PORT FOLLOWER_PORT
#   dataset-viz       : HF_DATASET_REPO_ID EPISODE_INDEX
#   train / eval      : 인자를 CLI 에 직접 전달 (env var 불필요)
# =============================================================================


# ── Arm 직렬 포트 ──────────────────────────────────────────────────────────────
# Leader/Follower Arm 이 연결된 WSL2/Linux 장치 경로
# CH343 칩이 cdc_acm 드라이버로 ttyACM* 에 잡힘 (ttyUSB 아님 주의)
LEADER_PORT=/dev/ttyACM0
FOLLOWER_PORT=/dev/ttyACM1

# ── 카메라 디바이스 경로 ────────────────────────────────────────────────────────
# UVC 카메라: 캡처 노드(짝수)와 메타데이터 노드(홀수) 쌍으로 존재
# belly cam — 전면부 고정 시점 (/dev/video0 캡처 노드)
BELLY_CAM_DEV=/dev/video0
BELLY_CAM_META_DEV=/dev/video1

# wrist cam — 손목 장착 시점 (/dev/video2 캡처 노드)
WRIST_CAM_DEV=/dev/video2
WRIST_CAM_META_DEV=/dev/video3

# ── OpenCV camera_index ────────────────────────────────────────────────────────
# cv2.VideoCapture(index) 에 전달되는 값 / /dev/videoN → index = N
BELLY_CAM_INDEX=0
WRIST_CAM_INDEX=2

# ── 카메라 해상도 / FPS ────────────────────────────────────────────────────────
# v4l2-ctl --list-formats-ext 로 확인한 지원 해상도
# Integrated_Webcam_HD 지원: 640x480@25fps, 1280x720@30fps(MJPEG)
CAM_WIDTH=640
CAM_HEIGHT=480
CAM_FPS=25
# 카메라 warmup 대기 시간(초) — WSL2/Docker에서 UVC 초기화에 1초 이상 소요
# TimeoutError: Timed out waiting for frame 발생 시 이 값을 늘릴 것 (권장: 5초)
CAM_WARMUP_S=5
# 카메라 fourcc 
CAM_FOURCC=MJPG


# ── 기기 타입 (calibrate / setup-motors / find-joint-limits) ──────────────────
# 로봇 타입: so101_follower | so100_follower | bi_so100_follower | ...
ROBOT_TYPE=so101_follower
# 텔레옵 타입: so101_leader | so100_leader | ...
TELEOP_TYPE=so101_leader

# calibrate / setup-motors 대상: robot (팔로워 암) | teleop (리더 암)
CALIBRATE_TARGET=robot

# find-joint-limits 텔레오퍼레이션 탐색 제한 시간(초)
TELEOP_TIME_S=30


# ── record 설정 ───────────────────────────────────────────────────────────────
# HF Hub 리포지토리 ID: '{hf_username}/{dataset_name}'
# record / replay / dataset-viz 모드에서 공통으로 사용
HF_DATASET_REPO_ID=

# 에피소드당 작업 설명 (자유 문자열, lerobot-record --dataset.single_task)
SINGLE_TASK=pick and place

# 수집할 에피소드 수 (--dataset.num_episodes)
NUM_EPISODES=50

# 에피소드 1회 녹화 시간(초) (--dataset.episode_time_s)
EPISODE_TIME_S=60

# 에피소드 간 환경 초기화 대기 시간(초) (--dataset.reset_time_s)
RESET_TIME_S=30

# 데이터셋 저장 fps (--dataset.fps) — teleop fps(CAM_FPS) 와 독립적으로 설정 가능
RECORD_FPS=30

# HF Hub 업로드 여부: true | false (--dataset.push_to_hub)
PUSH_TO_HUB=true

# 추가 lerobot-record 인자 (공백 구분 문자열)
# 예: RECORD_EXTRA_ARGS=--resume=true --dataset.video=false
RECORD_EXTRA_ARGS=


# ── replay 설정 ───────────────────────────────────────────────────────────────
# 재생할 에피소드 인덱스 (0-based, --dataset.episode)
EPISODE_INDEX=0

# 추가 lerobot-replay 인자
REPLAY_EXTRA_ARGS=


# ── dataset-viz 설정 ──────────────────────────────────────────────────────────
# 시각화 모드: local (로컬 뷰어) | distant (WebSocket 서버)
# distant 모드: 클라이언트에서 `rerun ws://HOST:VIZ_WS_PORT` 로 접속
VIZ_MODE=local
VIZ_WS_PORT=9087


# ── teleop 추가 인자 (레거시) ─────────────────────────────────────────────────
# 추가 lerobot-teleoperate 인자
TELEOP_EXTRA_ARGS=


# ── HuggingFace Hub ───────────────────────────────────────────────────────────
# https://huggingface.co/settings/tokens 에서 발급 (write 권한 필요)
HF_TOKEN=
HF_USER=


# ── Weights & Biases ──────────────────────────────────────────────────────────
WANDB_API_KEY=


# ── GR00T 정책 서버 (gr00t-train 서비스) ─────────────────────────────────────
# 로드할 모델 경로 (HF Hub ID 또는 로컬 경로)
GR00T_MODEL_PATH=nvidia/GR00T-N1.6-3B
# 학습 시 사용한 embodiment tag 와 일치시킬 것
GR00T_EMBODIMENT_TAG=NEW_EMBODIMENT
